<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Loop Saboteur</title>
    <organization>com.amfas</organization>

    <!-- System-wide install; requires admin password (standard for audio plugins). -->
    <domains enable_localSystem="true" enable_anywhere="false" enable_currentUserHome="false"/>

    <!-- Single-screen install. No customisation; users get AU + VST3 together. -->
    <options customize="never" require-scripts="false" rootVolumeOnly="true" hostArchitectures="arm64,x86_64"/>

    <!-- Minimum OS matches CMAKE_OSX_DEPLOYMENT_TARGET. -->
    <volume-check>
        <allowed-os-versions>
            <os-version min="10.13"/>
        </allowed-os-versions>
    </volume-check>

    <welcome file="welcome.txt" mime-type="text/plain"/>

    <!-- Two component packages, stitched together by productbuild.
         The file names here must match what release.sh builds via pkgbuild. -->
    <choices-outline>
        <line choice="loopsaboteur.au"/>
        <line choice="loopsaboteur.vst3"/>
    </choices-outline>

    <choice id="loopsaboteur.au"
            title="Audio Unit (AU)"
            description="Loop Saboteur AU plugin for Logic Pro, GarageBand, and other AU hosts. Installs to /Library/Audio/Plug-Ins/Components."
            start_selected="true">
        <pkg-ref id="com.amfas.loopsaboteur.au"/>
    </choice>

    <choice id="loopsaboteur.vst3"
            title="VST3"
            description="Loop Saboteur VST3 plugin for Ableton Live, Cubase, Studio One, REAPER, and other VST3 hosts. Installs to /Library/Audio/Plug-Ins/VST3."
            start_selected="true">
        <pkg-ref id="com.amfas.loopsaboteur.vst3"/>
    </choice>

    <pkg-ref id="com.amfas.loopsaboteur.au">LoopSaboteur_AU.pkg</pkg-ref>
    <pkg-ref id="com.amfas.loopsaboteur.vst3">LoopSaboteur_VST3.pkg</pkg-ref>
</installer-gui-script>
